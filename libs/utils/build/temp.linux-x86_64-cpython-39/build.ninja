ninja_required_version = 1.3
cxx = c++

cflags = -pthread -B /data-store/zengrh/envs/qyh_tas/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /data-store/zengrh/envs/qyh_tas/include -I/data-store/zengrh/envs/qyh_tas/include -fPIC -O2 -isystem /data-store/zengrh/envs/qyh_tas/include -fPIC -I/data-store/zengrh/envs/qyh_tas/lib/python3.9/site-packages/torch/include -I/data-store/zengrh/envs/qyh_tas/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/data-store/zengrh/envs/qyh_tas/lib/python3.9/site-packages/torch/include/TH -I/data-store/zengrh/envs/qyh_tas/lib/python3.9/site-packages/torch/include/THC -I/data-store/zengrh/envs/qyh_tas/include/python3.9 -c
post_cflags = -fopenmp -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=nms_1d_cpu -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc





build /data-store/zengrh/qianyihao/Ego/actionformer_release/libs/utils/build/temp.linux-x86_64-cpython-39/./csrc/nms_cpu.o: compile /data-store/zengrh/qianyihao/Ego/actionformer_release/libs/utils/csrc/nms_cpu.cpp






